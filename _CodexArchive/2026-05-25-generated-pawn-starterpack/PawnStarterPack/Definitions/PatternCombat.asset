  m_Script: {fileID: 11500000, guid: b890cf0fcd3e4e1290d1b98d7425014f, type: 3}
  m_Name: PatternCombat
  m_EditorClassIdentifier: NeonBlack.Gameplay.Data::NeonBlack.Gameplay.Data.Definitions.RuntimePatternDefinition
  patternId: pattern.combat
  displayName: Combat
  description: Use this when gameplay needs attacks, hitboxes, hurtboxes, health,
    reactions, damage, brawler actions, fighter moves, or combat sequences.
  capabilityFamily: 3
  participantEmbodiment: 1
  supportedControlSurfaces: 00000000030000000500000008000000
  requiredRuntimeSystems:
  - CombatActionDefinition
  - CombatSequenceDefinition
  - HealthComponent and HitBox as needed
  optionalRuntimeSystems:
  - PawnCombatProfile
  - ActorCombatReactionProfile
  - WorldHealthBar
